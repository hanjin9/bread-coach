# ─── 서버 ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT (최소 32자 이상 랜덤 문자열) ─────────────────
JWT_SECRET=change-this-to-a-random-string-minimum-32-characters

# ─── MySQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=bread_coach

# ─── 토스페이먼츠 (국내 결제) ─────────────────────────
# https://developers.tosspayments.com 에서 발급
TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# ─── Stripe (해외 결제) ───────────────────────────────
# https://dashboard.stripe.com/apikeys 에서 발급
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Anthropic (AI 피드백, 선택사항) ─────────────────
# 없으면 규칙 기반 피드백으로 동작
ANTHROPIC_API_KEY=sk-ant-...

# ─── Firebase (소셜 로그인, 선택사항) ─────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ─── AWS S3 (미디어 저장, 선택사항) ──────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=bread-coach-media
